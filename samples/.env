# SAMCO Stocknote Node.js Bridge - sample runner config
#
# Fill in the AES-encrypted values produced per:
#   https://docs-tradeapi.samco.in/session/generate-token
#
# `npm run <script>` auto-loads this file via `ts-node -r dotenv/config`.

# Required for `session-token`, `sample-client`, and `quick-start`.
SAMCO_API_KEY=<REPLACE_WITH_YOUR_API_KEY>
SAMCO_API_SECRET=<REPLACE_WITH_YOUR_API_SECRET>

# Opt-ins for `npm run quick-start`. Streaming samples run ~60 seconds each
# and then exit. PlaceOrder is destructive (real order on a real exchange) -
# leave false unless intended.
SAMCO_RUN_PLACE_ORDER=false
SAMCO_RUN_STREAMING=true
